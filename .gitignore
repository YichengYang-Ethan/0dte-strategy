# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Environment
.env
.env.*
venv/
.venv/

# Data (large files, don't commit)
data/raw/
data/cache/
*.parquet
*.csv
*.h5
!data/sample/

# Credentials
*.pem
*secret*
*credential*
*token*

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
# Research reports in logs/*.md are tracked (contain verdicts, diagnostics)
# Raw runtime logs (*.log) are ignored
logs/*.log
logs/__pycache__/

# Results (regenerable)
results/
backtest_output/
